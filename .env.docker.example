# Example Docker environment for the SCFCA proof-of-concept.
# Copy to .env for local overrides, or export matching shell variables.
# Do not use these placeholder values as production secrets.

DATABASE_URL=postgresql://user:password@postgres:5432/scfca
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=scfca
SECRET_KEY=change_me_to_a_long_random_secret
DEBUG=false
SCFCA_DEBUG=false
